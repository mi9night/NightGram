{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/calls/layout,_N_T_/(app)/calls/page,_N_T_/calls"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/calls/__PAGE__",
    "/!KGFwcCk/calls",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}