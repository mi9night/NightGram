{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/support/layout,_N_T_/(app)/support/page,_N_T_/support"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/support/__PAGE__",
    "/!KGFwcCk/support",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}