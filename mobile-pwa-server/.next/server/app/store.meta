{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/store/layout,_N_T_/(app)/store/page,_N_T_/store"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/store/__PAGE__",
    "/!KGFwcCk/store",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}