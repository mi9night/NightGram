# =============================================================================
#  NightGram Web — Environment Variables
#  Copy this file to `.env.local` and fill in real values.
# =============================================================================

# -------- App --------
NEXT_PUBLIC_APP_NAME=NightGram
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------- Supabase (Database / Postgres / Auth helpers) --------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# -------- Backend API (Node.js + Express, deployed on Railway) --------
# Public base URL used by the browser (CORS-enabled)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Server-side Vercel proxy fallback (same value as NEXT_PUBLIC_API_URL in production)
BACKEND_API_URL=http://localhost:4000/api

# -------- Auth (JWT issued by the backend) --------
JWT_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# -------- Socket.io (real-time messaging, served by the same backend) --------
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# -------- WebRTC calls --------
# STUN can be public; TURN should be your own coturn/Twilio/Xirsys/etc. for production reliability.
NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# -------- Stripe (Night Store + Premium subscriptions) --------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Stripe price IDs (create these in the Stripe dashboard)
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxxxxxxxxxx

# NightCoins — packages map to Stripe one-time prices
STRIPE_PRICE_COINS_500=price_xxxxxxxxxxxxx
STRIPE_PRICE_COINS_1200=price_xxxxxxxxxxxxx
STRIPE_PRICE_COINS_2500=price_xxxxxxxxxxxxx

# App URL the backend uses for redirects / webhooks
APP_WEBHOOK_RETURN_URL=http://localhost:3000/store
# -------- Donation automation --------
# Shared secret for /api/payments/* webhooks. Send as x-nightgram-secret header or ?secret=
DONATION_WEBHOOK_SECRET=replace_with_random_secret
DONATIONALERTS_WEBHOOK_SECRET=replace_with_random_secret
DONATEX_WEBHOOK_SECRET=replace_with_random_secret

# -------- Safety / Anti-spam --------
# Optional future distributed limiter. If empty, backend uses safe in-memory cooldowns per instance.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -------- Music / integrations OAuth --------
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
NEXT_PUBLIC_SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id

