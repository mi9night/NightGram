# Backend env (Railway)
PORT=4000
CLIENT_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# JWT
JWT_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxx
STRIPE_PRICE_COINS_500=price_xxxxx
STRIPE_PRICE_COINS_1200=price_xxxxx
STRIPE_PRICE_COINS_2500=price_xxxxx
APP_WEBHOOK_RETURN_URL=http://localhost:3000/store
# -------- Donation automation --------
# Shared secret for /api/payments/* webhooks. Send as x-nightgram-secret header or ?secret=
DONATION_WEBHOOK_SECRET=replace_with_random_secret
DONATIONALERTS_WEBHOOK_SECRET=replace_with_random_secret
DONATEX_WEBHOOK_SECRET=replace_with_random_secret

# -------- Safety / Anti-spam --------
# Optional future distributed limiter. If empty, backend uses in-memory cooldowns per Railway instance.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -------- Music / integrations OAuth --------
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
NEXT_PUBLIC_SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id

