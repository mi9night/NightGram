# Backend env (Railway)
PORT=4000
# Comma-separated public web origins. Desktop localhost origins are allowed automatically.
CLIENT_URL=http://localhost:3000
CLIENT_ORIGINS=
API_READ_RATE_LIMIT=600
API_WRITE_RATE_LIMIT=180

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# JWT
JWT_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Stable encryption key for authenticator TOTP secrets. Do not rotate while 2FA is enabled.
TWO_FACTOR_ENCRYPTION_KEY=replace_with_a_long_stable_random_string

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxx
STRIPE_PRICE_COINS_500=price_xxxxx
STRIPE_PRICE_COINS_1200=price_xxxxx
STRIPE_PRICE_COINS_2500=price_xxxxx
APP_WEBHOOK_RETURN_URL=http://localhost:3000/store
# -------- Donation automation --------
# Shared secret for /api/payments/* webhooks. Send as x-nightgram-secret header or ?secret=
DONATION_WEBHOOK_SECRET=replace_with_random_secret
DONATIONALERTS_WEBHOOK_SECRET=replace_with_random_secret
DONATEX_WEBHOOK_SECRET=replace_with_random_secret

# -------- Safety / Anti-spam --------
# Optional future distributed limiter. If empty, backend uses in-memory cooldowns per Railway instance.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -------- Music / integrations OAuth --------
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
NEXT_PUBLIC_SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id


# -------- WebRTC / TURN --------
# Comma-separated STUN and TURN endpoints. TURN is strongly recommended for public calls.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_URLS=turn:YOUR_TURN_HOST:3478?transport=udp,turn:YOUR_TURN_HOST:3478?transport=tcp,turns:YOUR_TURN_HOST:5349?transport=tcp
# Preferred: coturn REST shared secret. The backend creates short-lived credentials per user.
TURN_SHARED_SECRET=replace_with_coturn_static_auth_secret
TURN_TTL_SECONDS=3600
# How long an unanswered call rings before it is marked missed (15-120 seconds).
CALL_RING_TIMEOUT_SECONDS=60
# Alternative for providers that issue one fixed login. Leave blank when TURN_SHARED_SECRET is used.
TURN_USERNAME=
TURN_CREDENTIAL=

# -------- Web Push / mobile background notifications --------
# Generate once with: npm run push:keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@nightgram.app

# Native Android push (Firebase Cloud Messaging HTTP v1)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Native iOS push (APNs token key)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
APNS_BUNDLE_ID=app.nightgram.mobile
APNS_PRODUCTION=false
