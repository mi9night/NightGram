# Public HTTPS address of the deployed NightGram frontend.
NIGHTGRAM_MOBILE_URL=https://app.example.com

# Domains that may stay inside the native WebView, comma-separated.
NIGHTGRAM_MOBILE_ALLOW_NAVIGATION=app.example.com

# Stable IDs. Change them before the first store release only.
NIGHTGRAM_ANDROID_APP_ID=app.nightgram.mobile
NIGHTGRAM_IOS_BUNDLE_ID=app.nightgram.mobile
